# =============================================================================
# SochDB Environment Variables - Sample Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Azure OpenAI Configuration (for LLM features)
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your_api_key_here
AZURE_OPENAI_API_BASE=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name

# -----------------------------------------------------------------------------
# Groq Configuration (for LLM features)
# -----------------------------------------------------------------------------
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------------------------------------
# Azure Embedding Configuration (for vector search)
# -----------------------------------------------------------------------------
# Create at: https://pypi.org/manage/account/token/
PYPI_API_TOKEN=pypi-your_token_here

# -----------------------------------------------------------------------------
# Crates.io Publishing (for releases)
# -----------------------------------------------------------------------------
# Create at: https://crates.io/settings/tokens
CRATES_IO_TOKEN=your_token_here
